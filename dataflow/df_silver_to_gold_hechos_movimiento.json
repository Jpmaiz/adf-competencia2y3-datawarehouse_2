{
	"name": "df_silver_to_gold_hechos_movimiento",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sourceMovimientos"
				},
				{
					"dataset": {
						"referenceName": "ds_gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "sourceDimTiempo"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "convertirFecha"
				},
				{
					"name": "prepararMovimiento"
				},
				{
					"name": "joinTiempo"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as string,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(12,2),",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourceMovimientos",
				"source(output(",
				"          id_tiempo as integer,",
				"          fecha as date,",
				"          dia as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          semestre as integer,",
				"          anio as short,",
				"          semana_iso as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourceDimTiempo",
				"sourceMovimientos derive(fecha_movimiento_date = iif(\r",
				"    instr(fecha_movimiento, '/') == 0 && instr(fecha_movimiento, '-') == 0,\r",
				"    toDate(fecha_movimiento, 'yyyyMMdd'),\r",
				"    iif(\r",
				"        toInteger(left(fecha_movimiento, 4)) >= 1900,\r",
				"        toDate(fecha_movimiento, 'yyyy/MM/dd'),\r",
				"        iif(\r",
				"            instr(fecha_movimiento, '/') > 0,\r",
				"            toDate(fecha_movimiento, 'dd/MM/yyyy'),\r",
				"            iif(\r",
				"                toInteger(left(fecha_movimiento, 2)) > 12,\r",
				"                toDate(fecha_movimiento, 'dd-MM-yyyy'),\r",
				"                iif(\r",
				"                    toInteger(substring(fecha_movimiento, 4, 2)) > 12,\r",
				"                    toDate(fecha_movimiento, 'MM-dd-yyyy'),\r",
				"                    toDate(fecha_movimiento, 'dd-MM-yyyy')\r",
				"                )\r",
				"            )\r",
				"        )\r",
				"    )\r",
				")) ~> convertirFecha",
				"convertirFecha derive(mov_anio = year(fecha_movimiento_date),",
				"          mov_mes = month(fecha_movimiento_date),",
				"          mov_dia = dayOfMonth(fecha_movimiento_date)) ~> prepararMovimiento",
				"prepararMovimiento, sourceDimTiempo join(mov_anio == anio",
				"     && mov_mes == mes",
				"     && mov_dia == dia,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinTiempo"
			]
		}
	}
}