						"typeProperties": {
							"scripts": [
								{
									"type": "NonQuery",
									"text": "ALTER TABLE gold.hechos_movimiento_personal NOCHECK CONSTRAINT ALL;\nSET IDENTITY_INSERT gold.hechos_movimiento_personal ON;\nTRUNCATE TABLE gold.hechos_movimiento_personal;\nWITH fechas_parseadas AS (\n    SELECT id_movimiento, id_efectivo, id_unidad_destino, id_rango, id_tipo,\n        antiguedad_anios, salario_mensual, observaciones,\n        CASE \n            WHEN fecha_movimiento NOT LIKE '%/%' AND fecha_movimiento NOT LIKE '%-%' THEN TRY_CONVERT(DATE, fecha_movimiento, 112)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_movimiento, 4)) >= 1900 AND fecha_movimiento LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_movimiento, 111)\n            WHEN fecha_movimiento LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_movimiento, 103)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_movimiento, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_movimiento, 105)\n            WHEN TRY_CONVERT(INT, SUBSTRING(fecha_movimiento, 4, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_movimiento, 110)\n            ELSE TRY_CONVERT(DATE, fecha_movimiento, 105)\n        END AS fecha_parsed\n    FROM silver.movimientos_personal\n)\nINSERT INTO gold.hechos_movimiento_personal (id_movimiento, id_tiempo, id_efectivo, id_unidad_destino, id_rango, id_tipo_movimiento, antiguedad_anios, salario_mensual, observaciones)\nSELECT p.id_movimiento, t.id_tiempo, p.id_efectivo, p.id_unidad_destino, p.id_rango, p.id_tipo, p.antiguedad_anios, p.salario_mensual, p.observaciones\nFROM fechas_parseadas p INNER JOIN gold.dim_tiempo t ON t.fecha = p.fecha_parsed;\nSET IDENTITY_INSERT gold.hechos_movimiento_personal OFF;\nALTER TABLE gold.hechos_movimiento_personal CHECK CONSTRAINT ALL;"
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					},
