						"typeProperties": {
							"scripts": [
								{
									"type": "NonQuery",
									"text": "ALTER TABLE gold.hechos_operacion NOCHECK CONSTRAINT ALL;\nSET IDENTITY_INSERT gold.hechos_operacion ON;\nTRUNCATE TABLE gold.hechos_operacion;\nWITH fechas_parseadas AS (\n    SELECT id_operacion, id_tipo, id_unidad_resp, id_zona, nombre_operacion,\n        efectivos_desplegados, vehiculos_utilizados, duracion_dias, costo_operacion,\n        resultado, detenidos, area_km2, incidentes,\n        CASE \n            WHEN fecha_inicio NOT LIKE '%/%' AND fecha_inicio NOT LIKE '%-%' THEN TRY_CONVERT(DATE, fecha_inicio, 112)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_inicio, 4)) >= 1900 AND fecha_inicio LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_inicio, 111)\n            WHEN fecha_inicio LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_inicio, 103)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_inicio, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_inicio, 105)\n            WHEN TRY_CONVERT(INT, SUBSTRING(fecha_inicio, 4, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_inicio, 110)\n            ELSE TRY_CONVERT(DATE, fecha_inicio, 105)\n        END AS fecha_inicio_parsed,\n        CASE \n            WHEN fecha_fin NOT LIKE '%/%' AND fecha_fin NOT LIKE '%-%' THEN TRY_CONVERT(DATE, fecha_fin, 112)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_fin, 4)) >= 1900 AND fecha_fin LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_fin, 111)\n            WHEN fecha_fin LIKE '%/%' THEN TRY_CONVERT(DATE, fecha_fin, 103)\n            WHEN TRY_CONVERT(INT, LEFT(fecha_fin, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_fin, 105)\n            WHEN TRY_CONVERT(INT, SUBSTRING(fecha_fin, 4, 2)) > 12 THEN TRY_CONVERT(DATE, fecha_fin, 110)\n            ELSE TRY_CONVERT(DATE, fecha_fin, 105)\n        END AS fecha_fin_parsed,\n        ROW_NUMBER() OVER (PARTITION BY id_operacion ORDER BY id_operacion) AS rn\n    FROM silver.operaciones\n),\nsin_duplicados AS (SELECT * FROM fechas_parseadas WHERE rn = 1)\nINSERT INTO gold.hechos_operacion (id_hecho, id_tiempo_inicio, id_tiempo_fin, id_unidad_resp, id_tipo_operacion, id_zona, nombre_operacion, efectivos_desplegados, vehiculos_utilizados, duracion_dias, costo_operacion, resultado, detenidos, area_km2, incidentes)\nSELECT p.id_operacion, ti.id_tiempo, tf.id_tiempo, p.id_unidad_resp, p.id_tipo, p.id_zona, p.nombre_operacion, p.efectivos_desplegados, p.vehiculos_utilizados, p.duracion_dias, p.costo_operacion, p.resultado, p.detenidos, p.area_km2, p.incidentes\nFROM sin_duplicados p\nINNER JOIN gold.dim_tiempo ti ON ti.fecha = p.fecha_inicio_parsed\nINNER JOIN gold.dim_tiempo tf ON tf.fecha = p.fecha_fin_parsed;\nSET IDENTITY_INSERT gold.hechos_operacion OFF;\nALTER TABLE gold.hechos_operacion CHECK CONSTRAINT ALL;"
								}
							],
