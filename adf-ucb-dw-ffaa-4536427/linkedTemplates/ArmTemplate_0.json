{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-ucb-dw-ffaa-4536427"
		},
		"ls_oltp_ffaa_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_oltp_ffaa\""
		},
		"ls_sql_dw_ffaa_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_sql_dw_ffaa\""
		},
		"ls_oltp_ffaa_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "server01-fuerzas-armadas-bolivia.database.windows.net"
		},
		"ls_oltp_ffaa_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "erp-fuerzas-armadas-bolivia"
		},
		"ls_oltp_ffaa_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "userpar2"
		},
		"ls_sql_dw_ffaa_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-ucb-sisger-ffaa-4536427.database.windows.net"
		},
		"ls_sql_dw_ffaa_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw_ffaa_bolivia"
		},
		"ls_sql_dw_ffaa_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminfaa"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ls_oltp_ffaa')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ls_oltp_ffaa_properties_typeProperties_server')]",
					"database": "[parameters('ls_oltp_ffaa_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_oltp_ffaa_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_oltp_ffaa_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_sql_dw_ffaa')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ls_sql_dw_ffaa_properties_typeProperties_server')]",
					"database": "[parameters('ls_sql_dw_ffaa_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_sql_dw_ffaa_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_sql_dw_ffaa_password')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}